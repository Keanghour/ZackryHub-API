# App
APP_NAME="ZackryHub API"
APP_VERSION="1.0.0"
DEBUG=True
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# PostgreSQL
DATABASE_URL=xxxx


# JWT
SECRET_KEY=xxxx
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email (Gmail SMTP)
MAIL_USERNAME=xxxx
MAIL_PASSWORD=xxxx
MAIL_FROM=xxxx
MAIL_FROM_NAME=ZackryHub API
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# Frontend URL (used in reset link)
FRONTEND_URL=xxxx

# Rate Limiting
RATE_LIMIT_AUTH=xxxx
RATE_LIMIT_DEFAULT=xxxx

# Production 
# RATE_LIMIT_AUTH=5/minute
# RATE_LIMIT_DEFAULT=60/minute
